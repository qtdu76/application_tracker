NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public browser key. Prefer the new sb_publishable_ key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy public keys are still supported.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only elevated key for admin user deletion. Prefer the new sb_secret_ key.
SUPABASE_SECRET_KEY=

# Legacy elevated key is still supported.
SUPABASE_SERVICE_ROLE_KEY=
